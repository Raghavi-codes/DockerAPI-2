pipeline {
    agent any
     
     environment {
            MAVEN_HOME = 'D:\\java\\PracticeMS\\apache-maven-3.9.5'
            }
   
           stages{
        stage('Build JAR') {
            steps {
                bat '"%MAVEN_HOME%\\bin\\mvn" clean package -DskipTests'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'set DOCKER_BUILDKIT=0&& docker build -t springboot-app:latest .'
            }
        }

        stage('Deploy using Docker Compose') {
            steps {
                bat 'docker-compose down'
                bat 'docker-compose up -d'
            }
        }
    }
}